<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 작은 말풍선 점 (오른쪽 아래) -->
    <item android:gravity="bottom|right">
        <shape android:shape="oval">
            <size android:width="14dp" android:height="14dp"/>
            <solid android:color="#FFEBD8"/>
            <stroke android:width="1.2dp" android:color="#402512"/>
        </shape>
        <!-- 왼쪽으로 이동 -->
        <padding android:right="6dp" android:bottom="6dp"/>
    </item>

    <!-- 큰 말풍선 본체 (왼쪽으로 위치) -->
    <item android:right="10dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFEBD8"/>
            <corners android:radius="24dp"/>
            <stroke android:width="1.5dp" android:color="#402512"/>

            <padding
                android:left="20dp"
                android:top="16dp"
                android:right="10dp"
                android:bottom="16dp"/>
        </shape>
    </item>

</layer-list>
