<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mypage_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFEEE0"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="40dp"
        android:paddingBottom="10dp"
        android:paddingHorizontal="24dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:id="@+id/layout_logo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/app_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:contentDescription="@string/app_name_desc"
                android:textSize="32sp"
                android:textColor="#5D3316"
                android:fontFamily="@font/paperlogy_7" />

            <ImageView
                android:id="@+id/img_logo"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/photolog_logo"
                android:contentDescription="@string/app_logo_desc"
                android:layout_marginStart="2dp" />
        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_top_action"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:minWidth="132dp"
            android:paddingHorizontal="18dp"
            android:text="요청 관리"
            android:fontFamily="@font/paperlogy_7"
            android:textSize="30sp"
            android:textColor="#5D3316"
            android:background="@drawable/button_background"
            android:visibility="gone" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/scroll_mypage"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/root_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <View
                android:id="@+id/view_top_divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#5D3316" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="24dp"
                android:paddingTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/box_bg"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvMyPage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="마이페이지"
                        android:fontFamily="@font/paperlogy_6"
                        android:textSize="20sp"
                        android:textColor="#A16D49"
                        android:layout_marginBottom="12dp" />

                    <ImageView
                        android:id="@+id/profile"
                        android:layout_width="150dp"
                        android:layout_height="150dp"
                        android:src="@drawable/profile"
                        android:layout_marginBottom="10dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/tvNickname"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/paperlogy_6"
                        android:text="닉네임"
                        android:textSize="30sp"
                        android:textColor="#5D3316"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvDiaryCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/paperlogy_6"
                        android:textSize="20sp"
                        android:text="작성한 일기 수 : 0"
                        android:textColor="#5D3316" />

                    <TextView
                        android:id="@+id/tvFamilyCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="추가한 가족 수 : 0"
                        android:textSize="20sp"
                        android:fontFamily="@font/paperlogy_6"
                        android:textColor="#5D3316"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/section_no_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="24dp"
                android:paddingTop="16dp"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_no_group_msg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="아직 가족 그룹이 없습니다.\n그룹에 가입해보세요."
                    android:textColor="#5D3316"
                    android:textSize="28sp"
                    android:fontFamily="@font/paperlogy_7"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="14dp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_join_group"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="그룹 참여하기"
                    android:fontFamily="@font/paperlogy_7"
                    android:textSize="22sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/login_button_bg" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_create_group"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:text="그룹 생성하기"
                    android:textSize="22sp"
                    android:fontFamily="@font/paperlogy_7"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/login_button_bg" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/section_my_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="24dp"
                android:paddingTop="16dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvMyGroupTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="나의 그룹"
                    android:textColor="#A16D49"
                    android:fontFamily="@font/paperlogy_6"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"
                    android:layout_gravity="center_horizontal" />

                <TextView
                    android:id="@+id/tvGroupEmptyMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="아직 참여한 가족이 없어요."
                    android:textColor="#6A3E20"
                    android:textSize="16sp"
                    android:fontFamily="@font/paperlogy_5"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="10dp"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/group_member_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <View
                android:id="@+id/view_bottom_divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="30dp"
                android:background="#5D3316" />

            <LinearLayout
                android:id="@+id/privacy_box"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:paddingHorizontal="24dp"
                android:paddingTop="30dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/box_bg"
                    android:orientation="vertical"
                    android:padding="10sp">

                    <TextView
                        android:layout_marginStart="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="개인정보 보호"
                        android:textColor="#5D3316"
                        android:textSize="27sp"
                        android:fontFamily="@font/paperlogy_7"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_marginStart="10dp"
                        android:id="@+id/tv_privacy_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5sp"
                        android:fontFamily="@font/paperlogy_5"
                        android:text="데이터 삭제 및 탈퇴를 진행할 수 있어요."
                        android:textColor="#6A3E20"
                        android:textSize="20sp" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_delete_ai_data"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:text="AI 및 개인정보 전체 삭제"
                        android:textSize="22sp"
                        android:fontFamily="@font/paperlogy_7"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/login_button_bg"
                        app:backgroundTint="#8C4E2E" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_withdraw"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="10dp"
                        android:textSize="22sp"
                        android:text="회원 탈퇴"
                        android:fontFamily="@font/paperlogy_7"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/login_button_bg"
                        app:backgroundTint="#6F3B20" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>