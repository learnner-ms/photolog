<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFEEE0"
    android:orientation="vertical">

    <!-- 상단 바 -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="40dp"
        android:paddingBottom="10dp"
        android:paddingHorizontal="24dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:id="@+id/layout_logo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/paperlogy_7"
                android:text="@string/app_name"
                android:textColor="#5D3316"
                android:textSize="32sp" />

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="2dp"
                android:src="@drawable/photolog_logo" />
        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>

    <!-- 본문 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="30dp"
        android:paddingTop="25dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="그룹 생성"
                android:fontFamily="@font/paperlogy_7"
                android:textColor="#5C3A22"
                android:textSize="35sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/group_name"
                android:layout_width="280dp"
                android:layout_height="50dp"
                android:layout_marginTop="20dp"
                android:inputType="text"
                android:background="@drawable/edittext_bg"
                android:hint="그룹 이름"
                android:textColorHint="#B7A79A"
                android:textColor="#5D3316"
                android:padding="10dp"
                android:textSize="17sp"
                android:fontFamily="@font/paperlogy_6"
                android:textCursorDrawable="@null"
                />

            <EditText
                android:id="@+id/max_member"
                android:layout_width="280dp"
                android:layout_height="50dp"
                android:layout_marginTop="15dp"
                android:background="@drawable/edittext_bg"
                android:hint="최대 인원 수"
                android:textColorHint="#B7A79A"
                android:inputType="number"
                android:textColor="#5D3316"
                android:padding="10dp"
                android:textSize="17sp"
                android:fontFamily="@font/paperlogy_6"
                android:textCursorDrawable="@null"
                />

            <TextView
                android:id="@+id/tvGroupError"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="모든 칸을 채워주세요!"
                android:textColor="#8B4513"
                android:textSize="12sp"
                android:paddingLeft="10dp"
                android:visibility="gone" />

            <android.widget.Button
                android:id="@+id/btnLogin"
                android:layout_width="280dp"
                android:layout_height="50dp"
                android:layout_marginTop="15dp"
                android:background="@drawable/login_button_bg"
                android:text="그룹 생성하기"
                android:textColor="#FFFFFF"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tvGoJoinDirect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:text="이미 그룹이 있어요 (초대코드 입력)"
                android:textColor="#6A3E20"
                android:textSize="15sp"
                android:fontFamily="@font/paperlogy_5"
                android:clickable="true"
                android:focusable="true"
                android:padding="6dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/groupCodeLayout"
            android:layout_width="280dp"
            android:layout_height="232dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/edittext_bg"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="그룹 코드"
                android:textColor="#5C3A22"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/groupCode"
                android:layout_width="240dp"
                android:layout_height="70dp"
                android:layout_margin="15dp"
                android:background="@drawable/login_button_bg"
                android:fontFamily="@font/paperlogy_6"
                android:gravity="center"
                android:text="000000"
                android:textColor="#FFFFFF"
                android:textSize="25sp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>