<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFEEE0"
    android:orientation="vertical"
    android:paddingHorizontal="30dp"
    android:layout_gravity="center_horizontal"
    android:paddingTop="50dp">

    <!-- 로고 클릭 영역 (왼쪽 정렬) -->
    <LinearLayout
        android:id="@+id/layout_logo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="32sp"
            android:textColor="#5D3316"
            android:fontFamily="@font/paperlogy_7" />

        <ImageView
            android:layout_width="52sp"
            android:layout_height="52sp"
            android:src="@drawable/photolog_logo"
            android:layout_margin="2dp" />
    </LinearLayout>


    <TextView
        android:layout_width="380dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:fontFamily="@font/paperlogy_7"

        android:text="계정 정보를 확인 후,\n비밀번호를 재설정할 수 있어요."
        android:textColor="#5C3A22"
        android:textSize="28sp"
        android:textStyle="bold" />

    <EditText
        android:layout_gravity="center_horizontal"
        android:layout_width="280dp"
        android:layout_height="45dp"
        android:hint="이메일 주소"
        android:layout_marginTop="20dp"
        android:background="@drawable/edittext_bg"
        android:padding="10dp"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <EditText
            android:layout_width="160dp"
            android:layout_height="45dp"
            android:layout_gravity="center"
            android:layout_marginRight="10dp"
            android:background="@drawable/edittext_bg"
            android:hint="아이디"
            android:padding="10dp" />

        <android.widget.Button
            android:layout_width="110dp"
            android:layout_height="45dp"
            android:layout_gravity="center"
            android:background="@drawable/login_button_bg"
            android:text="인증번호 발송"
            android:textColor="#FFFFFF"
            android:textSize="16dp"

            android:padding="10dp" />
    </LinearLayout>
    <EditText
        android:layout_gravity="center_horizontal"
        android:layout_width="280dp"
        android:layout_height="45dp"
        android:hint="인증번호 (6자리)"
        android:layout_marginTop="10dp"
        android:inputType="textPassword"
        android:background="@drawable/edittext_bg"
        android:padding="10dp"/>



    <!-- 회원가입 버튼 -->
    <android.widget.Button
        android:id="@+id/goFindPwd"
        android:layout_gravity="center_horizontal"
        android:layout_width="280dp"
        android:layout_height="50dp"
        android:layout_marginTop="20dp"

        android:background="@drawable/login_button_bg"
        android:text="확인"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"/>
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center"
        android:layout_marginTop="20dp">


        <TextView
            android:id="@+id/tvLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="로그인"
            android:textSize="20sp"
            android:textColor="#000000"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  |  "
            android:textSize="20sp"
            android:textColor="#000000"/>

        <TextView
            android:id="@+id/tvFindId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="아이디 찾기"
            android:textSize="20sp"
            android:textColor="#000000"/>
    </LinearLayout>
</LinearLayout>
