<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFEEE0"
    android:orientation="vertical">

    <!-- 상단 바 -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="40dp"
        android:paddingBottom="10dp"
        android:paddingHorizontal="24dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:id="@+id/layout_logo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="32sp"
                android:textColor="#5D3316"
                android:fontFamily="@font/paperlogy_7" />

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="2dp"
                android:src="@drawable/photolog_logo" />
        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>

    <!-- 본문 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="30dp"
        android:paddingTop="55dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/paperlogy_7"
            android:text="계정 정보를 확인 후,\n비밀번호를 재설정할 수 있어요."
            android:textColor="#5C3A22"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="start" />

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="280dp"
            android:layout_height="45dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/edittext_bg"
            android:hint="이메일 주소"
            android:inputType="textEmailAddress"
            android:padding="10dp"
            android:textSize="17sp"
            android:textColor="#5D3316"
            android:textColorHint="#B7A79A"
            android:fontFamily="@font/paperlogy_6"
            android:textCursorDrawable="@null" />

        <LinearLayout
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etUserId"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:background="@drawable/edittext_bg"
                android:hint="아이디"
                android:padding="10dp"
                android:textSize="17sp"
                android:textColor="#5D3316"
                android:textColorHint="#B7A79A"
                android:fontFamily="@font/paperlogy_6"
                android:textCursorDrawable="@null" />

            <android.widget.Button
                android:id="@+id/btnSendCode"
                android:layout_width="140dp"
                android:layout_height="45dp"
                android:background="@drawable/login_button_bg"
                android:text="인증번호 발송"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:padding="10dp" />
        </LinearLayout>

        <EditText
            android:id="@+id/etCode"
            android:layout_width="280dp"
            android:layout_height="45dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/edittext_bg"
            android:hint="인증번호 (6자리)"
            android:inputType="numberPassword"
            android:padding="10dp"
            android:textSize="17sp"
            android:textColor="#5D3316"
            android:textColorHint="#B7A79A"
            android:fontFamily="@font/paperlogy_6"
            android:textCursorDrawable="@null" />

        <TextView
            android:id="@+id/tvPwdError"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="모든 칸을 채워주세요."
            android:textColor="#8B4513"
            android:textSize="12sp"
            android:visibility="gone" />

        <android.widget.Button
            android:id="@+id/goFindPwd"
            android:layout_width="280dp"
            android:layout_height="50dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/login_button_bg"
            android:text="확인"
            android:textColor="#FFFFFF"
            android:textSize="23sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/tvLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="로그인"
                android:textSize="20sp"
                android:textColor="#5C3A22" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  |  "
                android:textSize="20sp"
                android:textColor="#5C3A22" />

            <TextView
                android:id="@+id/tvFindId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="아이디 찾기"
                android:textSize="20sp"
                android:textColor="#5C3A22" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>