<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFEEE0"
    android:orientation="vertical"
    android:paddingHorizontal="30dp"
    android:paddingTop="50dp">

    <LinearLayout
        android:id="@+id/layout_logo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="32sp"
            android:textColor="#5D3316"
            android:fontFamily="@font/paperlogy_7" />

        <ImageView
            android:layout_width="52sp"
            android:layout_height="52sp"
            android:src="@drawable/photolog_logo"
            android:layout_margin="2dp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="40dp"
        android:gravity="center_horizontal"
        android:text="회원 가입"
        android:textColor="#5C3A22"
        android:textSize="35sp"
        android:fontFamily="@font/paperlogy_7"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/signName"
        android:layout_width="280dp"
        android:layout_height="45dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="20dp"
        android:hint="이름"
        android:background="@drawable/edittext_bg"
        android:padding="10dp" />

    <EditText
        android:id="@+id/signId"
        android:layout_width="280dp"
        android:layout_height="45dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:hint="아이디"
        android:background="@drawable/edittext_bg"
        android:padding="10dp" />

    <EditText
        android:id="@+id/signPwd"
        android:layout_width="280dp"
        android:layout_height="45dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:hint="비밀번호"
        android:inputType="textPassword"
        android:background="@drawable/edittext_bg"
        android:padding="10dp" />

    <EditText
        android:id="@+id/signPwdCheck"
        android:layout_width="280dp"
        android:layout_height="45dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:hint="비밀번호 재입력"
        android:inputType="textPassword"
        android:background="@drawable/edittext_bg"
        android:padding="10dp" />

    <TextView
        android:id="@+id/tvError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_gravity="start"
        android:paddingLeft="40dp"
        android:text="오류 메시지"
        android:textColor="#8B4513"
        android:textSize="12sp"
        android:visibility="gone" />

    <CheckBox
        android:id="@+id/chkAll"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:text="포토로그 전체약관에 동의합니다."
        android:textColor="#5C3A22"
        android:textSize="17sp"
        android:textStyle="bold"
        app:buttonTint="@color/checkbox_tint" />

    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <CheckBox
            android:id="@+id/chkUse"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:buttonTint="@color/checkbox_tint" />

        <TextView
            android:id="@+id/tvTermsUse"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="포토로그 이용약관 동의 (필수)"
            android:textColor="#5C3A22"
            android:textSize="16sp"
            android:paddingStart="4dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <CheckBox
            android:id="@+id/chkPrivacy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:buttonTint="@color/checkbox_tint" />

        <TextView
            android:id="@+id/tvTermsPrivacy"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="개인정보 처리방침 (필수)"
            android:textColor="#5C3A22"
            android:textSize="16sp"
            android:paddingStart="4dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <CheckBox
            android:id="@+id/chkAd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:buttonTint="@color/checkbox_tint" />

        <TextView
            android:id="@+id/tvTermsAd"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="맞춤형 광고 정보 수신 동의 (선택)"
            android:textColor="#5C3A22"
            android:textSize="16sp"
            android:paddingStart="4dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnSignup"
        android:layout_width="280dp"
        android:layout_height="50dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="@drawable/login_button_bg"
        android:backgroundTint="@null"
        app:backgroundTint="@null"
        android:text="회원 가입"
        android:textColor="#FFFFFF"
        android:textSize="30sp"
        android:textStyle="bold" />
</LinearLayout>