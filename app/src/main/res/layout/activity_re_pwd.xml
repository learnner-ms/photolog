<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFEEE0"
    android:orientation="vertical">

    <!-- 상단 바 -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="40dp"
        android:paddingBottom="10dp"
        android:paddingHorizontal="24dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:id="@+id/layout_logo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="32sp"
                android:textColor="#5D3316"
                android:fontFamily="@font/paperlogy_7" />

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="2dp"
                android:src="@drawable/photolog_logo" />
        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>

    <!-- 본문 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="30dp"
        android:paddingTop="45dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_horizontal"
            android:text="비밀번호 재설정"
            android:textColor="#5C3A22"
            android:textSize="30sp"
            android:fontFamily="@font/paperlogy_7"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etNewPwd"
            android:layout_width="280dp"
            android:layout_height="45dp"
            android:layout_marginTop="20dp"
            android:hint="새 비밀번호"
            android:inputType="textPassword"
            android:background="@drawable/edittext_bg"
            android:padding="10dp"
            android:textSize="17sp"
            android:textColor="#5D3316"
            android:textColorHint="#B7A79A"
            android:fontFamily="@font/paperlogy_6"
            android:textCursorDrawable="@null" />

        <EditText
            android:id="@+id/etNewPwdCheck"
            android:layout_width="280dp"
            android:layout_height="45dp"
            android:layout_marginTop="10dp"
            android:hint="새 비밀번호 재입력"
            android:inputType="textPassword"
            android:background="@drawable/edittext_bg"
            android:padding="10dp"
            android:textSize="17sp"
            android:textColor="#5D3316"
            android:textColorHint="#B7A79A"
            android:fontFamily="@font/paperlogy_6"
            android:textCursorDrawable="@null" />

        <TextView
            android:id="@+id/tvPasswordGuide"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="비밀번호는 8~20자, 영문/숫자/특수문자를 포함해야 합니다."
            android:textColor="#8B5A2B"
            android:textSize="12sp"
            android:fontFamily="@font/paperlogy_6" />

        <TextView
            android:id="@+id/tvPwdError"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="#8B4513"
            android:textSize="12sp"
            android:fontFamily="@font/paperlogy_6"
            android:visibility="gone" />

        <android.widget.Button
            android:id="@+id/goRePwd"
            android:layout_width="280dp"
            android:layout_height="50dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/login_button_bg"
            android:text="확인"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>